---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import PublicationList from '../components/PublicationList.astro';
import NewsList from '../components/NewsList.astro';
import site from '../data/site.json';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => path.startsWith('/') ? `${base}${path.slice(1)}` : path;
---

<BaseLayout title={site.labName}>
  <section class="hero">
    <div class="hero-inner">
      <div>
        <p class="hero-kicker">{site.shortName} at NYCU Mechanical Engineering</p>
        <h1>{site.labName}</h1>
        <p>{site.tagline}</p>
        <div class="hero-actions">
          <a class="button primary" href={withBase('/research/')}>Explore Research</a>
          <a class="button secondary" href={withBase('/contact/')}>Contact the Lab</a>
        </div>
      </div>
      <aside class="hero-panel" aria-label="Lab snapshot">
        <div>
          <span>Research Output</span>
          <strong>132</strong>
          <p>entries imported from the public publication profile</p>
        </div>
        <div>
          <span>Core Areas</span>
          <strong>4</strong>
          <p>microfluidics, plasma, robotics, and biomedical devices</p>
        </div>
        <div>
          <span>Home Base</span>
          <strong>NYCU</strong>
          <p>Mechanical Engineering, Hsinchu, Taiwan</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="section-kicker">Research Themes</p>
        <h2>Microscale systems for real-world measurement and manipulation.</h2>
      </div>
      <p>
        IMLAB connects microfluidics, plasma processing, robotic manipulation, and
        biomedical engineering through experimental platforms that can be updated as
        the lab portfolio grows.
      </p>
    </div>
    <ProjectGrid />
  </section>

  <section class="band">
    <div class="section">
      <div class="section-header">
        <div>
          <p class="section-kicker">Recent Work</p>
          <h2>Recent journal publications</h2>
        </div>
        <a class="button primary" href={withBase('/publications/')}>All Publications</a>
      </div>
      <PublicationList featuredOnly={true} />
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="section-kicker">Lab Updates</p>
        <h2>News</h2>
      </div>
    </div>
    <NewsList />
  </section>
</BaseLayout>
