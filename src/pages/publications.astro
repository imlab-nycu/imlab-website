---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationList from '../components/PublicationList.astro';
---

<BaseLayout title="Publications">
  <header class="page-title">
    <p class="section-kicker">Publications</p>
    <h1>Full publication list.</h1>
    <p>
      Imported from the public IMLAB publication profile and grouped by books,
      patents, journal publications, and conference publications. Edit
      <code>src/data/publications.json</code> to refine entries, add DOI labels,
      or update new papers.
    </p>
  </header>
  <section class="section">
    <PublicationList />
  </section>
</BaseLayout>
