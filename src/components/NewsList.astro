---
import news from '../data/news.json';
---

<div class="news-list">
  {news.map((item) => (
    <article class="news-item">
      <div class="date">{item.date}</div>
      <div>
        <h3>
          {item.url ? (
            <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
          ) : (
            item.title
          )}
        </h3>
        <p>{item.summary}</p>
      </div>
    </article>
  ))}
</div>
