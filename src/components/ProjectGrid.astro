---
import projects from '../data/projects.json';
---

<div class="grid">
  {projects.map((project, index) => (
    <article class={`card project-card project-card-${index + 1}`}>
      <div class="project-mark" aria-hidden="true"></div>
      <h3>{project.title}</h3>
      <p>{project.summary}</p>
      <div class="tags">
        {project.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </article>
  ))}
</div>
